{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"newCustomInstructions\": \"코드 블록 생략. 의사결정, 파일명:라인번호, 다음 작업만 보존. 반복 내용 압축.\"}'",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node packages/token-saver/dist/hook/pre-tool-use.js",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node workspace-knowledge-index/dist/index.js index 2>/dev/null || true",
            "timeout": 300,
            "statusMessage": "WKI 인덱싱 중..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Agent(*)",
      "Glob(*)",
      "Grep(*)",
      "Skill(*)",
      "NotebookEdit(*)"
    ]
  },
  "enabledMcpjsonServers": [
    "codex"
  ],
  "disabledMcpjsonServers": [
    "wki"
  ],
  "enableAllProjectMcpServers": true
}
