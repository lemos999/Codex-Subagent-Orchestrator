{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node workspace-knowledge-index/dist/index.js index 2>/dev/null || true",
            "timeout": 300,
            "statusMessage": "WKI 인덱싱 중..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Agent(*)",
      "Glob(*)",
      "Grep(*)",
      "Skill(*)",
      "NotebookEdit(*)"
    ]
  },
  "enabledMcpjsonServers": [
    "codex"
  ],
  "disabledMcpjsonServers": [
    "wki"
  ],
  "enableAllProjectMcpServers": true
}
