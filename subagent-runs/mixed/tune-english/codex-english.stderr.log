+    path.join(resolvedPaths.outputDir, 'run-summary.md'),
+    path.join(launcherDir, 'run-summary.md'),
+  );
+  if (resolvedPaths.debugLogFile) {
+    await copyIfExists(
+      resolvedPaths.debugLogFile,
       path.join(launcherDir, 'launcher-debug.log'),
     );
