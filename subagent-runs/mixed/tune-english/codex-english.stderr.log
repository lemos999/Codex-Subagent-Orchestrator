+    );
+
+    const runManifest = await fs.readFile(path.join(outputDir, 'run-manifest.md'), 'utf8');
+    const runSummary = await fs.readFile(path.join(outputDir, 'run-summary.md'), 'utf8');
+    const promptFile = await fs.readFile(
