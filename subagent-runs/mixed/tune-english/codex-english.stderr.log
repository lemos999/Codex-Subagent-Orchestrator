+      workspaceRoot: tempRoot,
+      outputDir,
+      stdoutText: 'raw writer output',
+      lastText: 'Created tests/artifacts/stage9.txt',
+      requiredPaths: [deliverableAbsolutePath],
+    });
+    const reviewerResult = await buildWorkerResult({
+      name: 'file-checker',
