+        requiredNonEmptyPaths: [],
+        extraArgs: [],
+        timeoutMs: 0,
+      },
+      {
+        name: 'file-checker',
+        engine: 'codex',
+        model: 'gpt-5-mini',
+        taskText: 'Verify tests/artifacts/stage9.txt exists and matches the contract',
