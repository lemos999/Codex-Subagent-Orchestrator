  stdoutText: string;
  stderrText?: string;
  lastText?: string;
  requiredPaths?: string[];
}

function buildResolvedPaths(workspaceRoot: string, outputDir: string): ResolvedPaths {
  return {
    workspaceRoot,
    outputDir,
    manifestFile: path.join(outputDir, 'orchestration-manifest.json'),
    summaryFile: path.join(outputDir, 'orchestration-summary.md'),
    debugLogFile: null,
