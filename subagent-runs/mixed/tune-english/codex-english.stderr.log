+    const missingDeliverable = path.join('tests', 'artifacts', 'missing-stage9.txt');
+
+    const codexResult = await buildWorkerResult({
+      name: 'codex-writer',
+      engine: 'codex',
+      stage: 1,
+      workerKind: 'implementer',
+      model: 'gpt-5',
