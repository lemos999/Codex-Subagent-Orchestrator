+      stdoutText: 'raw reviewer output',
+      lastText: 'ACCEPTED',
+    });
+
+    const workers = [
+      {
+        name: 'file-writer',
+        engine: 'codex',
+        model: 'gpt-5',
+        taskText: 'Create tests/artifacts/stage9.txt with exact content',
+        prompt: 'Create tests/artifacts/stage9.txt with exact content',
+        cwd: tempRoot,
+        outputDir,
+        sandbox: 'workspace-write',
+        kind: 'implementer',
+        stage: 1,
