function buildResolvedPaths(workspaceRoot, outputDir) {
  return {
    workspaceRoot,
    outputDir,
    manifestFile: path.join(outputDir, 'orchestration-manifest.json'),
    summaryFile: path.join(outputDir, 'orchestration-summary.md'),
    debugLogFile: null,
