+    );
+
+    assert.match(runManifest, /# Run Manifest - stage9-single/);
+    assert.match(runManifest, /prompts\/file-writer\.prompt\.md/);
+    assert.match(runManifest, /results\/file-checker\.result\.md/);
+    assert.match(
