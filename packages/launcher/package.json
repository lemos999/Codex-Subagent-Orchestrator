{
  "name": "@subagent/launcher",
  "version": "0.0.1",
  "description": "TypeScript launcher for subagent orchestration — replaces start-codex-subagent-team.ps1",
  "type": "module",
  "bin": {
    "subagent-launch": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npm run build && node --test --test-isolation=none",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": "^20 || ^22 || ^24"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6"
  }
}
