plot(poc, title="POC", color=color.yellow)
plot(vah, title="VAH", color=color.new(color.green, 0))
plot(val, title="VAL", color=color.new(color.red, 0))
plot(fibo_0618, title="Fibo 0.618", color=color.new(color.blue, 0))
plot(fibo_0786, title="Fibo 0.786", color=color.new(color.blue, 35))
plot(fibo_1000, title="Fibo 1.0", color=color.new(color.teal, 0))
plot(fibo_1500, title="Fibo 1.5", color=color.new(color.teal, 35))

plotchar(cvd_spike_signal, title="CVD Spike", char="S", location=location.top, color=color.fuchsia)
plotchar(reverse_spike_long, title="Reverse Spike Long", char="L", location=location.bottom, color=color.red)
plotchar(reverse_spike_short, title="Reverse Spike Short", char="H", location=location.top, color=color.green)
plotchar(not fibo_temporal_valid_long, title="Fibo Temporal Skip Long", char="T", location=location.bottom, color=color.orange)
plotchar(not fibo_temporal_valid_short, title="Fibo Temporal Skip Short", char="T", location=location.top, color=color.orange)
plotchar(triple_confluence_long, title="Triple Confluence Long", char="C", location=location.bottom, color=color.lime)
plotchar(triple_confluence_short, title="Triple Confluence Short", char="C", location=location.top, color=color.lime)

plot(na, title="MTS-V1 placeholder")
