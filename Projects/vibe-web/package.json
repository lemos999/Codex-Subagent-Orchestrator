{
  "name": "vibe-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run db:generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm run test && npm run build && npm run test:e2e",
    "db:seed": "node prisma/seed.mjs",
    "db:generate": "prisma generate",
    "db:migrate:status": "prisma migrate status --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prod:db:migrate:status": "node scripts/vercel-production-db.mjs status",
    "prod:db:migrate:deploy": "node scripts/vercel-production-db.mjs deploy",
    "deploy:prod:checked": "npm run lint && npm run test && npm run build && npm run prod:db:migrate:status && npm run prod:db:migrate:deploy && npm run prod:db:migrate:status && npx vercel deploy --prod --yes",
    "preview:env:check": "node scripts/check-preview-env.mjs",
    "preview:report": "node scripts/preview-report.mjs",
    "preview:doctor": "npm run preview:report && npm run preview:env:check",
    "preview:db:prepare": "npm run db:generate && npm run db:migrate:deploy && npm run db:seed && npm run db:migrate:status"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "7.7",
    "@sentry/nextjs": "^10.45.0",
    "@tanstack/react-query": "^5.95.2",
    "@tiptap/extension-color": "^3.22.3",
    "@tiptap/extension-highlight": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/extension-youtube": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@vercel/blob": "^1.1.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "fast-xml-parser": "^5.5.11",
    "lucide-react": "^1.0.1",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "pg": "^8.16.3",
    "prisma": "7.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-parse": "^9.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "unified": "^11.0.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.1"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
