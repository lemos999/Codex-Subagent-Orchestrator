# Trading Quest — Environment Variables
# Copy to .env and fill in your values.

# --- Telegram Alerts ---
TQ_TELEGRAM_BOT_TOKEN=your_bot_token_here
TQ_TELEGRAM_CHAT_ID=your_chat_id_here

# --- Binance ---
TQ_BINANCE_API_KEY=your_api_key
TQ_BINANCE_API_SECRET=your_api_secret
TQ_BINANCE_TESTNET=true

# --- General ---
TQ_DEFAULT_MARKET=us
TQ_INITIAL_CAPITAL=100000
TQ_DATA_CACHE_DIR=data
